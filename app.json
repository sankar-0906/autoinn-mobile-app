{
  "expo": {
    "name": "autocloud-mobile-app",
    "slug": "autocloud-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/464dc6d161864c69f60b59f4ad74113c00404235.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/464dc6d161864c69f60b59f4ad74113c00404235.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sankar-sr.autocloudmobileapp",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to photo library to upload documents",
        "NSPhotoLibraryAddUsageDescription": "This app needs access to photo library to upload documents",
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to find the nearest branch",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to find the nearest branch"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/464dc6d161864c69f60b59f4ad74113c00404235.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sankar_sr.autocloudmobileapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "thamizh5253",
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload documents.",
          "cameraPermission": "The app accesses your camera to take photos for document uploads."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2e1b01f7-b24e-4af4-b7d0-bcbf3d9e10c1"
      }
    }
  }
}
